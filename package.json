{
  "name": "usable-git-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "bun test packages/*/tests",
    "test:usable-git": "bun test packages/usable-git/tests",
    "test:git-mine": "bun test packages/git-mine/tests",
    "typecheck": "tsc --noEmit && tsc --noEmit -p packages/git-mine/tsconfig.json"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "typescript": "5.9.3"
  }
}
